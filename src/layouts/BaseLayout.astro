---
import '../styles/global.css';
import type { SiteSettings } from '../lib/siteSettings';

type Props = {
  title?: string;
  settings: SiteSettings;
};

const { title = 'Adam Pendleton', settings } = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4321';
const noindex = import.meta.env.PUBLIC_NOINDEX === 'true';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const cssVariables = [
  `--body-color: ${settings.bodyTextColor}`,
  `--background-color: ${settings.backgroundColor}`,
  `--background-image: url("${settings.desktopBackgroundImage || '/images/background-desktop.jpg'}")`,
  `--mobile-background-image: url("${settings.mobileBackgroundImage || '/images/background-mobile.jpg'}")`,
  `--background-position: ${settings.backgroundPosition}`,
  `--font-size: ${settings.fontSize}`,
  `--mobile-font-size-factor: ${settings.mobileFontSize}`,
  `--font-family: "${settings.font}", Arial, sans-serif`,
  `--font-weight: ${settings.fontWeight}`,
  `--blend: ${settings.blend ? 'multiply' : 'normal'}`,
  `--frame-height: ${settings.frameHeight}`,
].join('; ');
---

<!doctype html>
<html lang="en" style={cssVariables}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Adam Pendleton" />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    <slot />
  </body>
</html>
